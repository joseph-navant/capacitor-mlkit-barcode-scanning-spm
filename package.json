{
  "name": "@capacitor-mlkit/barcode-scanning",
  "version": "8.0.1",
  "description": "Capacitor plugin for ML Kit Barcode Scanning (SPM version).",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Plugin/",
    "Package.swift"
  ],
  "author": "Robin Genz <mail@robingenz.dev>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joseph-navant/capacitor-mlkit-barcode-scanning-spm.git"
  },
  "bugs": {
    "url": "https://github.com/joseph-navant/capacitor-mlkit-barcode-scanning-spm/issues"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "native"
  ],
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@capacitor/core": "8.0.0",
    "rimraf": "6.1.2",
    "rollup": "4.53.3",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@capacitor/core": ">=8.0.0"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
